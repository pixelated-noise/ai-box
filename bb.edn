{:paths ["src"]

 :tasks
 {:requires ([aibox.core :as ai])

  download
  {:doc  "Download the Alpine Linux aarch64 ISO"
   :task (ai/download)}

  boot
  {:doc     "Boot Alpine Linux live from ISO"
   :depends [download]
   :task    (ai/boot)}

  login
  {:doc  "Generate a long-lived OAuth token for Claude Code"
   :task (ai/login)}

  ssh
  {:doc  "SSH into the running VM"
   :task (ai/ssh)}

  net
  {:doc  "Network control: bb net [block|allow|status]"
   :task (case (first *command-line-args*)
           "block"  (ai/restrict-network)
           "allow"  (ai/open-network)
           "status" (ai/network-status)
           (println "Usage: bb net [block|allow|status]"))}

  clean
  {:doc  "Remove generated files (keeps ISO and OAuth token, use --logout to also remove token)"
   :task (ai/clean {:logout (some #{"--logout"} *command-line-args*)})}}}
